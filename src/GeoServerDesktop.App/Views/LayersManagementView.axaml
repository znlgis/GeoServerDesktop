<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GeoServerDesktop.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="GeoServerDesktop.App.Views.LayersManagementView"
             x:DataType="vm:LayersManagementViewModel">

    <Design.DataContext>
        <vm:LayersManagementViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="15" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding L.LayersTitle}" 
                               FontSize="24" 
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding L.LayersSubtitle}" 
                               FontSize="13"
                               Foreground="#666666"
                               Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="{Binding L.PublishLayer}"
                            Command="{Binding ShowCreateLayerDialogCommand}"
                            Background="#2196F3"
                            Foreground="White"
                            Padding="12,6"/>
                    <Button Content="{Binding L.Refresh}" 
                            Command="{Binding LoadLayersCommand}"
                            Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" ColumnDefinitions="250,*" Margin="10">
            <!-- Workspace Selector -->
            <Border Grid.Column="0" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    Padding="10"
                    Margin="0,0,10,0"
                    Background="White"
                    CornerRadius="4">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="{Binding L.WorkspaceLabel}" 
                                   FontWeight="Bold" 
                                   FontSize="14"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding L.SelectWorkspaceFilterLayersHint}" 
                                   FontSize="12"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <ListBox ItemsSource="{Binding Workspaces}"
                             SelectedItem="{Binding SelectedWorkspace}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" 
                                        Background="Transparent"
                                        CornerRadius="3">
                                    <TextBlock Text="{Binding}" FontSize="13"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Layers List + Publish Dialog -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto">
                <Border Grid.Row="0"
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        Padding="15"
                        Background="White"
                        CornerRadius="4">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                            <TextBlock Text="{Binding L.LayersTitle}" 
                                       FontWeight="Bold" 
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding SelectedWorkspace, StringFormat='Filter: {0}'}" 
                                       FontSize="12"
                                       Foreground="#666666"
                                       IsVisible="{Binding !!SelectedWorkspace}"/>
                        </StackPanel>

                        <!-- Layer List -->
                        <Grid>
                            <TextBlock Text="{Binding L.SelectWorkspaceToViewLayers}" 
                                       FontSize="14"
                                       Foreground="#999999"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding !SelectedWorkspace}"/>

                            <ScrollViewer IsVisible="{Binding !!SelectedWorkspace}">
                                <ItemsControl ItemsSource="{Binding Layers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E0E0E0" 
                                                    BorderThickness="1" 
                                                    Padding="15"
                                                    Margin="0,0,0,10"
                                                    Background="#FAFAFA"
                                                    CornerRadius="4">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Grid.Column="0" Spacing="5">
                                                        <TextBlock Text="{Binding Name}" 
                                                                   FontWeight="Bold" 
                                                                   FontSize="15"/>
                                                        <TextBlock Text="{Binding Type}" 
                                                                   FontSize="12"
                                                                   Foreground="#666666"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <TextBlock Text="Default Style:" 
                                                                       FontSize="11"
                                                                       Foreground="#666666"/>
                                                            <TextBlock Text="{Binding DefaultStyle.Name}" 
                                                                       FontSize="11"
                                                                       Foreground="#2196F3"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="5"
                                                                    IsVisible="{Binding !!Resource.Name}">
                                                            <TextBlock Text="Resource:" 
                                                                       FontSize="11"
                                                                       Foreground="#666666"/>
                                                            <TextBlock Text="{Binding Resource.Name}" 
                                                                       FontSize="11"
                                                                       Foreground="#666666"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    
                                                    <StackPanel Grid.Column="1" 
                                                                Orientation="Horizontal" 
                                                                Spacing="5"
                                                                VerticalAlignment="Center">
                                                        <Button Content="Edit" 
                                                                Padding="10,5"
                                                                FontSize="12"/>
                                                        <Button Content="Delete" 
                                                                Padding="10,5"
                                                                FontSize="12"
                                                                Background="#F44336"
                                                                Foreground="White"
                                                                Click="OnDeleteLayerClick"
                                                                Tag="{Binding}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Publish Layer Dialog -->
                <Border Grid.Row="0"
                        IsVisible="{Binding IsCreateLayerDialogVisible}"
                        Background="#80000000"
                        CornerRadius="4">
                    <Border Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="20"
                            MaxWidth="420"
                            MaxHeight="300"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{Binding L.PublishNewLayerTitle}" FontSize="16" FontWeight="Bold"/>
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" HorizontalAlignment="Stretch">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding L.DataStoreLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding DataStoreNames}"
                                          SelectedItem="{Binding NewLayerDataStore}"
                                          HorizontalAlignment="Stretch"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding L.LayerNameLabel}" VerticalAlignment="Center" Margin="0,8,10,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewLayerName}" Watermark="{Binding L.PublishedLayerNameHint}" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding L.NativeNameLabel}" VerticalAlignment="Center" Margin="0,8,10,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NewNativeName}" Watermark="{Binding L.NativeNameHint}" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding L.SrsLabel}" VerticalAlignment="Center" Margin="0,8,10,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding NewLayerSrs}" Watermark="e.g. EPSG:4326" Margin="0,8,0,0"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                <Button Content="{Binding L.Cancel}"
                                        Command="{Binding CancelCreateLayerCommand}"
                                        Padding="12,6"/>
                                <Button Content="{Binding L.PublishButton}"
                                        Command="{Binding CreateLayerCommand}"
                                        Background="#2196F3"
                                        Foreground="White"
                                        Padding="12,6"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="10,8" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusMessage}" 
                           VerticalAlignment="Center"
                           FontSize="12"/>
                <ProgressBar Grid.Column="1" 
                             Width="100"
                             Height="4"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
