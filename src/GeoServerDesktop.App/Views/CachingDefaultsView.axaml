<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GeoServerDesktop.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="GeoServerDesktop.App.Views.CachingDefaultsView"
             x:DataType="vm:CachingDefaultsViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Tile Caching Defaults" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Load" Command="{Binding LoadSettingsCommand}" ToolTip.Tip="Load caching defaults"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="15" MaxWidth="600">
                <!-- Enable/Disable -->
                <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Default Cache Configuration" FontWeight="Bold" FontSize="14"/>
                        <CheckBox Content="Enable Tile Caching by Default" IsChecked="{Binding IsEnabled}"/>
                    </StackPanel>
                </Border>

                <!-- Expiry Settings -->
                <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Default Expiry Settings" FontWeight="Bold" FontSize="14"/>
                        <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cache Expiry (seconds):" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="1"
                                          Value="{Binding DefaultExpireCache}"
                                          Minimum="0" Increment="3600"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Client Cache Expiry (seconds):" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="1"
                                          Value="{Binding DefaultExpireClients}"
                                          Minimum="0" Increment="3600"
                                          Margin="0,8,0,0"/>
                        </Grid>
                        <TextBlock Text="Set to 0 for no expiry." FontSize="12" Foreground="#666666"/>
                    </StackPanel>
                </Border>

                <!-- Info -->
                <Border Background="#E8F5E9" Padding="15" BorderBrush="#A5D6A7" BorderThickness="1" CornerRadius="4">
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#2E7D32"
                               Text="Note: These are global defaults. Individual layer caching settings can be configured in Layer Management."/>
                </Border>

                <!-- Save Button -->
                <Button Content="Save Settings"
                        Command="{Binding SaveSettingsCommand}"
                        Background="#4CAF50"
                        Foreground="White"
                        HorizontalAlignment="Left"
                        Padding="15,8"/>

                <!-- Loading Indicator -->
                <StackPanel Spacing="10" IsVisible="{Binding IsLoading}">
                    <TextBlock Text="Processing..." HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
