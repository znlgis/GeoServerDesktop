<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GeoServerDesktop.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="GeoServerDesktop.App.Views.GlobalSettingsView"
             x:DataType="vm:GlobalSettingsViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{Binding L.GlobalSettingsTitle}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="{Binding L.Load}" Command="{Binding LoadSettingsCommand}" ToolTip.Tip="{Binding L.LoadGlobalSettingsToolTip}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="15" MaxWidth="600">
                <!-- Contact Information -->
                <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding L.ContactInformation}" FontWeight="Bold" FontSize="14"/>
                        <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding L.ContactPersonLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ContactPerson}" Watermark="{Binding L.ContactPersonHint}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding L.OrganizationLabel}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ContactOrganization}" Watermark="{Binding L.OrganizationNameHint}" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding L.EmailLabel}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ContactEmail}" Watermark="{Binding L.EmailAddressHint}" Margin="0,8,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Server Configuration -->
                <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding L.ServerConfiguration}" FontWeight="Bold" FontSize="14"/>
                        <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding L.OnlineResourceLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OnlineResource}" Watermark="{Binding L.OnlineResourceUrlHint}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding L.ProxyBaseUrlLabel}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProxyBaseUrl}" Watermark="{Binding L.ProxyBaseUrlHint}" Margin="0,8,0,0"/>
                        </Grid>
                        <CheckBox Content="{Binding L.VerboseExceptions}" IsChecked="{Binding VerboseExceptions}"/>
                    </StackPanel>
                </Border>

                <!-- Save Button -->
                <Button Content="{Binding L.SaveSettings}"
                        Command="{Binding SaveSettingsCommand}"
                        Background="#4CAF50"
                        Foreground="White"
                        HorizontalAlignment="Left"
                        Padding="15,8"/>

                <!-- Loading Indicator -->
                <StackPanel Spacing="10" IsVisible="{Binding IsLoading}">
                    <TextBlock Text="{Binding L.Processing}" HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
