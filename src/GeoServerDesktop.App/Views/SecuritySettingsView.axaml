<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GeoServerDesktop.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="GeoServerDesktop.App.Views.SecuritySettingsView"
             x:DataType="vm:SecuritySettingsViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{Binding L.SecuritySettingsTitle}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="{Binding L.Load}" Command="{Binding LoadSettingsCommand}" ToolTip.Tip="{Binding L.LoadSecuritySettingsToolTip}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,280">
            <!-- ACL Rules List -->
            <Border Grid.Column="0" Margin="10" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="#F5F5F5" Padding="8" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                        <TextBlock Text="{Binding L.AccessControlRules}" FontWeight="Bold"/>
                    </Border>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding AclRules}"
                             Padding="5"/>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="#DDDDDD" VerticalAlignment="Stretch"/>

            <!-- Info Panel -->
            <StackPanel Grid.Column="2" Margin="10" Spacing="10">
                <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding L.InformationLabel}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding L.SecurityInfoText}"
                                   TextWrapping="Wrap" Opacity="0.7"/>
                        <TextBlock Text="{Binding L.SecurityFormatText}"
                                   FontStyle="Italic" TextWrapping="Wrap" Opacity="0.7"/>
                    </StackPanel>
                </Border>

                <!-- Loading Indicator -->
                <StackPanel Spacing="10" IsVisible="{Binding IsLoading}">
                    <TextBlock Text="{Binding L.Loading}" HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
