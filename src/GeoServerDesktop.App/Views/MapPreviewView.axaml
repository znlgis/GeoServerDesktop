<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GeoServerDesktop.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="GeoServerDesktop.App.Views.MapPreviewView"
             x:DataType="vm:MapPreviewViewModel">
    
    <Design.DataContext>
        <vm:MapPreviewViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="5" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="5">
                <Button Content="{Binding L.ResetButton}" 
                        Command="{Binding ZoomToExtentCommand}"
                        ToolTip.Tip="{Binding L.ResetViewToolTip}"/>
                <Button Content="{Binding L.ClearButton}" 
                        Command="{Binding ClearLayersCommand}"
                        ToolTip.Tip="{Binding L.ClearLayerToolTip}"/>
                <Separator Width="1" Height="20" Background="#CCCCCC" Margin="5,0"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           VerticalAlignment="Center"
                           Foreground="#666666"/>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Background="White" Padding="20">
            <Grid>
                <!-- Map placeholder or WMS information -->
                <ScrollViewer>
                    <StackPanel Spacing="20">
                        <TextBlock Text="{Binding L.MapPreviewTitle}" 
                                   FontSize="24" 
                                   FontWeight="Bold"/>
                        
                        <TextBlock Text="{Binding L.MapPreviewDescription}"
                                   TextWrapping="Wrap"
                                   FontSize="14"/>
                        
                        <StackPanel Spacing="10" IsVisible="{Binding !!PreviewUrl}">
                            <TextBlock Text="{Binding L.CurrentLayerWmsUrl}" 
                                       FontWeight="Bold"/>
                            <Border Background="#F5F5F5" 
                                    Padding="10" 
                                    BorderBrush="#CCCCCC" 
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <SelectableTextBlock Text="{Binding PreviewUrl}"
                                                     TextWrapping="Wrap"
                                                     FontFamily="Consolas,Courier New,monospace"
                                                     FontSize="12"/>
                            </Border>
                            
                            <TextBlock Text="{Binding L.WmsUrlUsageHint}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="#666666"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="10" IsVisible="{Binding !PreviewUrl}">
                            <TextBlock Text="{Binding L.HowToPreviewTitle}" 
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,20,0,0"/>
                            <TextBlock Text="{Binding L.PreviewStep1}"
                                       Margin="20,0,0,0"/>
                            <TextBlock Text="{Binding L.PreviewStep2}"
                                       Margin="20,0,0,0"/>
                            <TextBlock Text="{Binding L.PreviewStep3}"
                                       Margin="20,0,0,0"/>
                            <TextBlock Text="{Binding L.PreviewStep4}"
                                       Margin="20,0,0,0"/>
                        </StackPanel>
                        
                        <!-- Loading overlay -->
                        <StackPanel IsVisible="{Binding IsLoading}"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="{Binding L.Loading}" 
                                       FontSize="16" 
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <ProgressBar IsIndeterminate="True" 
                                         Width="200" 
                                         Margin="0,10,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Info panel -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" 
                           Text="{Binding L.MapPreviewTitle}" 
                           FontWeight="Bold" 
                           Margin="0,0,20,0"/>
                <TextBlock Grid.Column="1" 
                           Text="{Binding L.MapPreviewInfo}"
                           Foreground="#666666"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
