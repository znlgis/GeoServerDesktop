<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GeoServerDesktop.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="GeoServerDesktop.App.Views.UsersGroupsRolesView"
             x:DataType="vm:UsersGroupsRolesViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{Binding L.UsersGroupsRolesTitle}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="{Binding L.Refresh}" Command="{Binding LoadAllCommand}" ToolTip.Tip="{Binding L.ReloadAllToolTip}"/>
            </StackPanel>
        </Border>

        <!-- Tab Content -->
        <TabControl Grid.Row="1" Margin="10">

            <!-- Users Tab -->
            <TabItem Header="{Binding L.UsersTab}">
                <Grid ColumnDefinitions="*,Auto,300" Margin="5">
                    <!-- Users List -->
                    <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Background="#F5F5F5" Padding="8" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                                <TextBlock Text="{Binding L.UsersHeader}" FontWeight="Bold"/>
                            </Border>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Users}"
                                     SelectedItem="{Binding SelectedUser}"
                                     Padding="5"/>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4" Background="#DDDDDD" VerticalAlignment="Stretch"/>

                    <!-- User Actions Panel -->
                    <StackPanel Grid.Column="2" Margin="10" Spacing="10">
                        <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding L.CreateUser}" FontWeight="Bold" FontSize="14"/>
                                <TextBox Text="{Binding NewUsername}" Watermark="{Binding L.UsernameHint}"/>
                                <TextBox Text="{Binding NewPassword}" Watermark="{Binding L.PasswordHint}" PasswordChar="*"/>
                                <Button Content="{Binding L.CreateUserButton}"
                                        Command="{Binding CreateUserCommand}"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,6"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding L.DeleteUser}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedUser, StringFormat='Selected: {0}'}"
                                           TextWrapping="Wrap" Opacity="0.7"/>
                                <Button Content="{Binding L.DeleteSelectedUser}"
                                        Command="{Binding DeleteUserCommand}"
                                        Background="#F44336"
                                        Foreground="White"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,6"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding L.EditUser}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedUser, StringFormat='Selected: {0}'}"
                                           TextWrapping="Wrap" Opacity="0.7"/>
                                <TextBox Text="{Binding EditPassword}" Watermark="{Binding L.NewPasswordHint}" PasswordChar="*"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <CheckBox IsChecked="{Binding EditEnabled}" Content="{Binding L.EnabledCheckbox}"/>
                                </StackPanel>
                                <Button Content="{Binding L.UpdateUser}"
                                        Command="{Binding UpdateUserCommand}"
                                        Background="#FF9800"
                                        Foreground="White"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,6"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Groups Tab -->
            <TabItem Header="{Binding L.GroupsTab}">
                <Grid ColumnDefinitions="*,Auto,300" Margin="5">
                    <!-- Groups List -->
                    <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Background="#F5F5F5" Padding="8" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                                <TextBlock Text="{Binding L.GroupsHeader}" FontWeight="Bold"/>
                            </Border>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Groups}"
                                     SelectedItem="{Binding SelectedGroup}"
                                     Padding="5"/>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4" Background="#DDDDDD" VerticalAlignment="Stretch"/>

                    <!-- Group Actions Panel -->
                    <StackPanel Grid.Column="2" Margin="10" Spacing="10">
                        <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding L.CreateGroup}" FontWeight="Bold" FontSize="14"/>
                                <TextBox Text="{Binding NewGroupName}" Watermark="{Binding L.GroupNameHint}"/>
                                <Button Content="{Binding L.CreateGroupButton}"
                                        Command="{Binding CreateGroupCommand}"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,6"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding L.DeleteGroup}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedGroup, StringFormat='Selected: {0}'}"
                                           TextWrapping="Wrap" Opacity="0.7"/>
                                <Button Content="{Binding L.DeleteSelectedGroup}"
                                        Command="{Binding DeleteGroupCommand}"
                                        Background="#F44336"
                                        Foreground="White"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,6"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Roles Tab -->
            <TabItem Header="{Binding L.RolesTab}">
                <Grid ColumnDefinitions="*,Auto,300" Margin="5">
                    <!-- Roles List -->
                    <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Background="#F5F5F5" Padding="8" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                                <TextBlock Text="{Binding L.RolesHeader}" FontWeight="Bold"/>
                            </Border>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Roles}"
                                     SelectedItem="{Binding SelectedRole}"
                                     Padding="5"/>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4" Background="#DDDDDD" VerticalAlignment="Stretch"/>

                    <!-- Roles Info Panel -->
                    <StackPanel Grid.Column="2" Margin="10" Spacing="10">
                        <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding L.RolesReadOnly}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding L.RolesReadOnlyInfo}"
                                           TextWrapping="Wrap" Opacity="0.7"/>
                                <TextBlock Text="{Binding SelectedRole, StringFormat='Selected: {0}'}"
                                           TextWrapping="Wrap" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsLoading}">
                    <TextBlock Text="{Binding L.Processing}" VerticalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
