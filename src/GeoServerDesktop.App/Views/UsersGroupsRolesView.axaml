<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GeoServerDesktop.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="GeoServerDesktop.App.Views.UsersGroupsRolesView"
             x:DataType="vm:UsersGroupsRolesViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Users, Groups, and Roles" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Refresh" Command="{Binding LoadAllCommand}" ToolTip.Tip="Reload all users, groups and roles"/>
            </StackPanel>
        </Border>

        <!-- Tab Content -->
        <TabControl Grid.Row="1" Margin="10">

            <!-- Users Tab -->
            <TabItem Header="Users">
                <Grid ColumnDefinitions="*,Auto,300" Margin="5">
                    <!-- Users List -->
                    <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Background="#F5F5F5" Padding="8" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                                <TextBlock Text="Users" FontWeight="Bold"/>
                            </Border>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Users}"
                                     SelectedItem="{Binding SelectedUser}"
                                     Padding="5"/>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4" Background="#DDDDDD" VerticalAlignment="Stretch"/>

                    <!-- User Actions Panel -->
                    <StackPanel Grid.Column="2" Margin="10" Spacing="10">
                        <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Create User" FontWeight="Bold" FontSize="14"/>
                                <TextBox Text="{Binding NewUsername}" Watermark="Username"/>
                                <TextBox Text="{Binding NewPassword}" Watermark="Password" PasswordChar="*"/>
                                <Button Content="Create User"
                                        Command="{Binding CreateUserCommand}"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,6"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Delete User" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedUser, StringFormat='Selected: {0}'}"
                                           TextWrapping="Wrap" Opacity="0.7"/>
                                <Button Content="Delete Selected User"
                                        Command="{Binding DeleteUserCommand}"
                                        Background="#F44336"
                                        Foreground="White"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,6"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Groups Tab -->
            <TabItem Header="Groups">
                <Grid ColumnDefinitions="*,Auto,300" Margin="5">
                    <!-- Groups List -->
                    <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Background="#F5F5F5" Padding="8" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                                <TextBlock Text="Groups" FontWeight="Bold"/>
                            </Border>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Groups}"
                                     SelectedItem="{Binding SelectedGroup}"
                                     Padding="5"/>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4" Background="#DDDDDD" VerticalAlignment="Stretch"/>

                    <!-- Group Actions Panel -->
                    <StackPanel Grid.Column="2" Margin="10" Spacing="10">
                        <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Create Group" FontWeight="Bold" FontSize="14"/>
                                <TextBox Text="{Binding NewGroupName}" Watermark="Group name"/>
                                <Button Content="Create Group"
                                        Command="{Binding CreateGroupCommand}"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,6"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Delete Group" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedGroup, StringFormat='Selected: {0}'}"
                                           TextWrapping="Wrap" Opacity="0.7"/>
                                <Button Content="Delete Selected Group"
                                        Command="{Binding DeleteGroupCommand}"
                                        Background="#F44336"
                                        Foreground="White"
                                        HorizontalAlignment="Stretch"
                                        Padding="10,6"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Roles Tab -->
            <TabItem Header="Roles">
                <Grid ColumnDefinitions="*,Auto,300" Margin="5">
                    <!-- Roles List -->
                    <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Background="#F5F5F5" Padding="8" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                                <TextBlock Text="Roles" FontWeight="Bold"/>
                            </Border>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Roles}"
                                     SelectedItem="{Binding SelectedRole}"
                                     Padding="5"/>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4" Background="#DDDDDD" VerticalAlignment="Stretch"/>

                    <!-- Roles Info Panel -->
                    <StackPanel Grid.Column="2" Margin="10" Spacing="10">
                        <Border Background="#F5F5F5" Padding="15" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Roles (Read Only)" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="Roles are read-only. Use the GeoServer REST API directly to create or delete roles."
                                           TextWrapping="Wrap" Opacity="0.7"/>
                                <TextBlock Text="{Binding SelectedRole, StringFormat='Selected: {0}'}"
                                           TextWrapping="Wrap" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsLoading}">
                    <TextBlock Text="Processing..." VerticalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
